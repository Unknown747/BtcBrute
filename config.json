{
  "workerCount": 3,
  "addressesPerRound": 60,
  "perAddressDelayMs": 1500,
  "jitterMs": 400,
  "roundPauseMs": 30000,
  "errorBackoffMs": 15000,
  "requestTimeoutMs": 10000,
  "workIntervalMinutes": 30,
  "restPauseMinutes": 2,
  "endpoints": [
    { "type": "blockchain", "url": "https://blockchain.info/balance?active=" },
    { "type": "blockstream", "url": "https://blockstream.info/api/address/" },
    { "type": "mempool", "url": "https://mempool.space/api/address/" }
  ],
  "endpointStrategy": "failover",
  "addressTypes": {
    "uncompressed": false,
    "compressed": true,
    "segwit": true,
    "nestedSegwit": true,
    "multisig": false
  },
  "outputFile": "Lottery_BTC.txt",
  "verbose": true,
  "statsIntervalMs": 60000,
  "pauseOnHit": true,
  "stateFile": "state.json"
}
